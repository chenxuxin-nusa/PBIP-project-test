		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Metric_Equity_Multiple = MAX(f_simulation_output_summary[equity_multiple])
		displayFolder: Executive Summary\Executive Summary_
		lineageTag: 30f95d26-ca39-4b3a-b29b-71e3a6b19155

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Metric_Value_Format =
			
			var metric_value = [Metric_Value]
			return
			if(
			    SELECTEDVALUE(f_simulation_output_summary_executive_summary[metric]) in {"WAL Class A","WAL Class B","Equity Multiple"},FORMAT(metric_value,"0.00"),
			    FORMAT(metric_value,"#,##0")
			)
		displayFolder: Executive Summary\Executive Summary_
		lineageTag: 9299a359-a792-4dc4-a94f-4c3f4b559d85

	measure OC_Ratio =
			CALCULATE(
			    SUM(f_simulation_output_metric_daily[metric_value]),
			    f_simulation_output_metric_daily[metric_label] = "OC Ratio"
			)
		formatString: 0
		displayFolder: Daily Metrics
		lineageTag: a4eb21d5-99a2-4b5e-adc3-5f0d884bef17

	measure Target_OC = ```
			
			
			    SUM(d_simulated_abs[target_oc_ratio])
			
			```
		displayFolder: Daily Metrics
		lineageTag: bf5327a2-0ef3-4615-bb30-ed08d3d5b111

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'OC Ratio vs Target (110%)' = ```
			"OC Ratio vs Target " & "(" & FORMAT([Target_OC],"0%") & ")"
			
			```
		displayFolder: Daily Metrics
		lineageTag: bb3e64b0-72e0-433e-a320-4b1c4e6d9296

