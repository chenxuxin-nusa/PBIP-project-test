	partition d_simulated_abs = m
		mode: directQuery
		source =
				let
				    Source = Sql.Database(Server, Database, [Query="select #(lf)*,FORMAT(current_simulation_date, 'dd MMM yyyy', 'en-US') as filter_date#(lf)from pbi.dbo.simulated_abs#(lf)where status = 'COMPLETED'"])
				in
				    Source

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

